# Dependencies
node_modules/

# Build output
dist/

# Vite's transient config-loader artifacts (left behind if a build is killed)
vite.config.js.timestamp-*.mjs

# Design-system bundle zips — large binaries, regenerate from
# design-system-year2/ with: python tools/zip-bundle.py
*.zip

# Environment and secrets
.env
.env.*
*.local

# Plan and internal docs (contain references to secrets/infrastructure)
FORMS-INTEGRATION-PLAN.md

# OS files
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/

# Claude Code git worktrees — transient; never commit (they land as bare
# gitlinks with no .gitmodules and break checkout / Cloudflare Pages builds).
.claude/worktrees/
